<% const pageTitle = 'My Orders' %>
<div style="max-width:var(--container-width); margin:0 auto; padding:48px 24px 80px;">
    <h1 style="font-size:2rem; margin-bottom:32px;">My Orders</h1>

    <% if (orders.length === 0) { %>
        <div class="empty-state">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M9 9h6M9 13h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            <h3>No orders yet</h3>
            <p>Once you place an order, it will appear here.</p>
            <br><a href="/products" class="btn btn--primary">Browse Frames</a>
        </div>
    <% } else { %>
        <% orders.forEach(order => { %>
            <div class="order-card">
                <div class="order-card__head">
                    <div>
                        <div class="order-card__id">#<%= order.order_number %></div>
                        <div class="order-card__date">Placed on <%= new Date(order.created_at).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %></div>
                    </div>
                    <div style="display:flex; gap:8px; align-items:center;">
                        <% if (order.payment_method === 'UPI' && order.payment_status === 'pending') { %>
                            <span class="status-pill status-pending">Payment Needed</span>
                        <% } else if (order.payment_method === 'UPI' && order.payment_status === 'submitted') { %>
                            <span class="status-pill status-submitted">Payment Under Review</span>
                        <% } else if (order.payment_method === 'UPI' && order.payment_status === 'rejected') { %>
                            <span class="status-pill status-rejected">Payment Rejected</span>
                        <% } %>
                        <span class="status-pill status-<%= order.order_status %>"><%= order.order_status.charAt(0).toUpperCase() + order.order_status.slice(1) %></span>
                    </div>
                </div>
                <div class="order-card__footer">
                    <div class="order-card__total" style="font-family:var(--font-mono);">₹<%= Number(order.total_amount).toLocaleString('en-IN') %> · <%= order.payment_method %></div>
                    <a href="/orders/<%= order.id %>" class="btn btn--small btn--outline">View Details →</a>
                </div>
            </div>
        <% }) %>

        <% if (totalPages > 1) { %>
            <div class="pagination">
                <% for (let p = 1; p <= totalPages; p++) { %>
                    <a href="/orders?page=<%= p %>" class="<%= p === currentPage ? 'is-active' : '' %>"><%= p %></a>
                <% } %>
            </div>
        <% } %>
    <% } %>
</div>
