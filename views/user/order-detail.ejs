<% const pageTitle = 'Order #' + order.order_number %>
<div style="max-width:860px; margin:0 auto; padding:48px 24px 80px;">
    <div style="display:flex; align-items:center; gap:16px; flex-wrap:wrap; margin-bottom:32px;">
        <a href="/orders" style="color:var(--color-ink-soft); font-size:0.88rem;">← Back to Orders</a>
        <h1 style="font-size:1.7rem; margin-left:auto;">Order #<%= order.order_number %></h1>
        <span class="status-pill status-<%= order.order_status %>"><%= order.order_status.charAt(0).toUpperCase() + order.order_status.slice(1) %></span>
    </div>

    <!-- Status Timeline -->
    <%
    const STATUSES = ['placed','confirmed','packed','shipped','delivered'];
    const currentStatusIndex = STATUSES.indexOf(order.order_status);
    %>
    <% if (order.order_status !== 'cancelled') { %>
        <div class="order-timeline" style="margin-bottom:40px;">
            <% STATUSES.forEach((s, i) => { %>
                <div class="timeline-step <%= i <= currentStatusIndex ? 'is-complete' : '' %>">
                    <div class="timeline-step__dot">
                        <% if (i <= currentStatusIndex) { %>
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="white" stroke-width="3" stroke-linecap="round"/></svg>
                        <% } %>
                    </div>
                    <span><%= s.charAt(0).toUpperCase() + s.slice(1) %></span>
                </div>
            <% }) %>
        </div>
    <% } %>

    <div style="display:grid; grid-template-columns:1fr 340px; gap:28px;">
        <div>
            <!-- Items -->
            <div style="background:var(--color-card); border:1px solid var(--color-border); border-radius:var(--radius-lg); padding:24px; margin-bottom:20px;">
                <h3 style="margin-bottom:16px;">Items Ordered</h3>
                <% items.forEach(item => { %>
                    <div style="display:flex; gap:14px; align-items:center; padding:12px 0; border-bottom:1px solid var(--color-border);">
                        <div style="width:60px; height:60px; background:var(--color-bg-alt); padding:6px; flex-shrink:0;">
                            <img src="<%= item.product_image || '/images/placeholder-frame.svg' %>" alt="" style="width:100%; height:100%; object-fit:cover;">
                        </div>
                        <div style="flex:1;">
                            <div style="font-weight:600; font-size:0.92rem;"><%= item.product_name %></div>
                            <div style="font-size:0.8rem; color:var(--color-ink-soft);">₹<%= Number(item.price).toLocaleString('en-IN') %> × <%= item.quantity %></div>
                        </div>
                        <div style="font-family:var(--font-mono); font-weight:600;">₹<%= Number(item.line_total).toLocaleString('en-IN') %></div>
                    </div>
                <% }) %>
                <div style="display:flex; justify-content:space-between; padding-top:16px; font-size:1rem; font-weight:700;">
                    <span>Total</span>
                    <span style="font-family:var(--font-mono);">₹<%= Number(order.total_amount).toLocaleString('en-IN') %></span>
                </div>
            </div>

            <!-- Status History -->
            <% if (history && history.length > 0) { %>
                <div style="background:var(--color-card); border:1px solid var(--color-border); border-radius:var(--radius-lg); padding:24px;">
                    <h3 style="margin-bottom:16px;">Order Activity</h3>
                    <% history.forEach(h => { %>
                        <div style="display:flex; gap:14px; padding:10px 0; border-bottom:1px solid var(--color-border); font-size:0.88rem;">
                            <span class="status-pill status-<%= h.status %>" style="flex-shrink:0;"><%= h.status %></span>
                            <span style="color:var(--color-ink-soft);">
                                <%= h.note ? h.note + ' · ' : '' %>
                                <%= new Date(h.created_at).toLocaleString('en-IN') %>
                            </span>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <!-- Sidebar: address + actions -->
        <div>
            <% if (address) { %>
                <div style="background:var(--color-card); border:1px solid var(--color-border); border-radius:var(--radius-lg); padding:24px; margin-bottom:16px;">
                    <h4 style="margin-bottom:12px; font-size:0.88rem; text-transform:uppercase; letter-spacing:0.04em; color:var(--color-ink-soft);">Delivery Address</h4>
                    <div style="font-weight:600;"><%= address.full_name %></div>
                    <div style="font-size:0.88rem; color:var(--color-ink-soft); margin-top:4px; line-height:1.6;">
                        <%= address.address_line1 %><%= address.address_line2 ? ', ' + address.address_line2 : '' %>,<br>
                        <%= address.city %>, <%= address.state %> <%= address.pincode %><br>
                        Ph: <%= address.phone %>
                    </div>
                </div>
            <% } %>

            <div style="background:var(--color-card); border:1px solid var(--color-border); border-radius:var(--radius-lg); padding:24px; margin-bottom:16px;">
                <div style="display:flex; justify-content:space-between; font-size:0.9rem; padding:8px 0;">
                    <span style="color:var(--color-ink-soft);">Payment</span>
                    <span style="font-weight:600;"><%= order.payment_method === 'COD' ? 'Cash on Delivery' : 'UPI' %></span>
                </div>
                <div style="display:flex; justify-content:space-between; font-size:0.9rem; padding:8px 0;">
                    <span style="color:var(--color-ink-soft);">Payment Status</span>
                    <span class="status-pill status-<%= order.payment_status %>">
                        <%= order.payment_status === 'submitted' ? 'Under Review' : order.payment_status.charAt(0).toUpperCase() + order.payment_status.slice(1) %>
                    </span>
                </div>
                <div style="display:flex; justify-content:space-between; font-size:0.9rem; padding:8px 0;">
                    <span style="color:var(--color-ink-soft);">Placed</span>
                    <span><%= new Date(order.created_at).toLocaleDateString('en-IN') %></span>
                </div>
            </div>

            <!-- UPI Payment: pending — show QR + upload form -->
            <% if (order.payment_method === 'UPI' && order.payment_status === 'pending') { %>
                <div style="background:var(--color-card); border:2px solid var(--color-terracotta); border-radius:var(--radius-lg); padding:24px; margin-bottom:16px;">
                    <h4 style="margin-bottom:14px; color:var(--color-terracotta);">⚠ Payment Required</h4>
                    <% if (upiQrImage) { %>
                        <img src="<%= upiQrImage %>" alt="UPI QR Code" style="width:100%; max-width:200px; display:block; margin:0 auto 14px; background:#fff; padding:10px; border-radius:var(--radius-sm); box-shadow:var(--shadow-sm);">
                    <% } %>
                    <% if (upiId) { %>
                        <p style="text-align:center; font-size:0.8rem; color:var(--color-ink-soft);">Pay to</p>
                        <p style="text-align:center; font-family:var(--font-mono); font-weight:700; color:var(--color-terracotta); margin-bottom:16px;"><%= upiId %></p>
                    <% } %>

                    <form action="/orders/<%= order.id %>/payment-proof" method="POST" enctype="multipart/form-data">
                        <div class="form-group">
                            <label for="payment_screenshot">Upload Payment Screenshot *</label>
                            <input type="file" id="payment_screenshot" name="payment_screenshot" accept="image/*" required>
                        </div>
                        <div class="form-group">
                            <label for="transaction_id">UPI Transaction / Reference ID (optional)</label>
                            <input type="text" id="transaction_id" name="transaction_id" placeholder="e.g. 123456789012">
                        </div>
                        <button type="submit" class="btn btn--primary btn--full">Submit Payment Proof</button>
                    </form>
                </div>
            <% } %>

            <!-- UPI Payment: rejected — show reason + allow re-upload -->
            <% if (order.payment_method === 'UPI' && order.payment_status === 'rejected') { %>
                <div style="background:var(--color-error-bg); border:1.5px solid #e8c3ba; border-radius:var(--radius-lg); padding:24px; margin-bottom:16px;">
                    <h4 style="color:var(--color-error); margin-bottom:8px;">✕ Payment Not Verified</h4>
                    <p style="font-size:0.85rem; color:var(--color-error); margin-bottom:16px;">
                        <%= order.payment_rejection_reason || 'We could not verify your payment screenshot. Please try again.' %>
                    </p>
                    <% if (upiQrImage) { %>
                        <img src="<%= upiQrImage %>" alt="UPI QR Code" style="width:100%; max-width:180px; display:block; margin:0 auto 14px; background:#fff; padding:10px; border-radius:var(--radius-sm);">
                    <% } %>
                    <% if (upiId) { %>
                        <p style="text-align:center; font-family:var(--font-mono); font-weight:700; color:var(--color-terracotta); margin-bottom:16px;"><%= upiId %></p>
                    <% } %>
                    <form action="/orders/<%= order.id %>/payment-proof" method="POST" enctype="multipart/form-data">
                        <div class="form-group">
                            <label for="payment_screenshot2">Re-upload Payment Screenshot *</label>
                            <input type="file" id="payment_screenshot2" name="payment_screenshot" accept="image/*" required>
                        </div>
                        <div class="form-group">
                            <label for="transaction_id2">UPI Transaction / Reference ID</label>
                            <input type="text" id="transaction_id2" name="transaction_id" placeholder="e.g. 123456789012">
                        </div>
                        <button type="submit" class="btn btn--primary btn--full">Re-submit Payment Proof</button>
                    </form>
                </div>
            <% } %>

            <!-- UPI Payment: submitted — show "under review" + their uploaded screenshot -->
            <% if (order.payment_method === 'UPI' && order.payment_status === 'submitted') { %>
                <div style="background:#FFF9E6; border:1.5px solid #f0dca0; border-radius:var(--radius-lg); padding:24px; margin-bottom:16px; text-align:center;">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" style="color:#8B6800; margin:0 auto 10px;"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M12 7v5l3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    <h4 style="color:#8B6800; margin-bottom:6px;">Payment Under Review</h4>
                    <p style="font-size:0.82rem; color:#8B6800; margin-bottom:14px;">We've received your screenshot and are verifying it. This usually takes a few hours.</p>
                    <% if (order.payment_proof_image) { %>
                        <img src="/secure/payment-proof/<%= order.id %>" alt="Submitted screenshot" style="max-width:160px; border-radius:var(--radius-sm); border:1px solid var(--color-border); margin:0 auto;">
                    <% } %>
                </div>
            <% } %>

            <!-- UPI Payment: paid — confirmation -->
            <% if (order.payment_method === 'UPI' && order.payment_status === 'paid') { %>
                <div style="background:var(--color-success-bg); border:1.5px solid #c7ddc4; border-radius:var(--radius-lg); padding:20px; margin-bottom:16px; text-align:center;">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" style="color:var(--color-success); margin:0 auto 8px;"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <p style="color:var(--color-success); font-weight:600; font-size:0.9rem;">Payment Verified</p>
                </div>
            <% } %>

            <% if (['placed','confirmed'].includes(order.order_status)) { %>
                <form action="/orders/<%= order.id %>/cancel" method="POST" data-confirm="Are you sure you want to cancel this order? This cannot be undone.">
                    <button type="submit" class="btn btn--danger btn--full">Cancel Order</button>
                </form>
            <% } %>
        </div>
    </div>
</div>
