<% pageTitle = category ? 'Edit: ' + category.name : 'New Category'; layout = 'admin/layout' %>

<div style="max-width:640px;">
    <a href="/admin/categories" class="abtn abtn--ghost abtn--small" style="margin-bottom:16px; display:inline-flex;">← Back</a>

    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
        <div class="form-error-list"><ul><% errors.forEach(e => { %><li><%= e.msg %></li><% }) %></ul></div>
    <% } %>

    <form action="/admin/categories/<%= category ? category.id + '/edit' : 'new' %>" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="admin-form-section">
            <h3><%= category ? 'Edit Category' : 'New Frame Shape Category' %></h3>

            <div class="aform-group">
                <label for="name">Category Name *</label>
                <input type="text" id="name" name="name" value="<%= oldInput.name || '' %>" required placeholder="e.g. Heart Frames">
            </div>

            <div class="aform-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="3" placeholder="A short description shown on the homepage category grid."><%= oldInput.description || '' %></textarea>
            </div>

            <div class="aform-row">
                <div class="aform-group">
                    <label for="icon_shape">Shape Icon *</label>
                    <select id="icon_shape" name="icon_shape" required>
                        <% ['square','circle','heart','oval','hexagon','rectangle','polaroid','collage'].forEach(s => { %>
                            <option value="<%= s %>" <%= (oldInput.icon_shape || 'square') === s ? 'selected' : '' %>><%= s.charAt(0).toUpperCase() + s.slice(1) %></option>
                        <% }) %>
                    </select>
                    <span class="ahint">Used to render the shape icon on the category card.</span>
                </div>
                <div class="aform-group">
                    <label for="display_order">Display Order</label>
                    <input type="number" id="display_order" name="display_order" value="<%= oldInput.display_order || 0 %>" min="0">
                    <span class="ahint">Lower numbers appear first on the homepage.</span>
                </div>
            </div>

            <div class="aform-group">
                <label>Category Image (optional)</label>
                <label class="image-upload-area" for="image">
                    <input type="file" id="image" name="image" accept="image/*">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" style="color:var(--admin-ink-soft); margin:0 auto 8px;"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><circle cx="8.5" cy="8.5" r="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M21 15l-5-5L5 21" stroke="currentColor" stroke-width="1.5"/></svg>
                    <p style="font-size:0.82rem; color:var(--admin-ink-soft);">Click to choose an image</p>
                </label>
            </div>

            <div class="admin-toggle">
                <input type="checkbox" id="is_active" name="is_active" <%= (category ? category.is_active != 0 : true) ? 'checked' : '' %>>
                <label for="is_active">Active (visible in storefront)</label>
            </div>
        </div>

        <div style="display:flex; gap:12px;">
            <button type="submit" class="abtn abtn--primary"><%= category ? 'Save Changes' : 'Create Category' %></button>
            <a href="/admin/categories" class="abtn abtn--secondary">Cancel</a>
        </div>
    </form>
</div>
