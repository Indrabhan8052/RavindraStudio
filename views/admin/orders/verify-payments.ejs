<% pageTitle = 'Verify UPI Payments'; layout = 'admin/layout' %>

<div class="admin-card">
    <div class="admin-card__head">
        <h3>Pending Payment Verifications</h3>
        <span style="font-size:0.82rem; color:var(--admin-ink-soft);"><%= totalCount %> awaiting review</span>
    </div>

    <% if (orders.length === 0) { %>
        <div style="text-align:center; padding:60px 24px; color:var(--admin-ink-soft);">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" style="margin:0 auto 16px; color:var(--admin-border);"><path d="M9 12l2 2 4-4M21 12a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.5"/></svg>
            <h3 style="color:var(--admin-ink); margin-bottom:6px;">All caught up!</h3>
            <p>No payment screenshots are waiting for review right now.</p>
        </div>
    <% } else { %>
        <div class="admin-card__body" style="padding:0;">
            <% orders.forEach(order => { %>
                <div style="display:flex; gap:24px; padding:24px; border-bottom:1px solid var(--admin-border); align-items:flex-start;">

                    <!-- Screenshot thumbnail -->
                    <div style="flex-shrink:0;">
                        <% if (order.payment_proof_image) { %>
                            <a href="/secure/payment-proof/<%= order.id %>" target="_blank" title="View full size">
                                <img src="/secure/payment-proof/<%= order.id %>" alt="Payment screenshot" style="width:120px; height:120px; object-fit:cover; border-radius:8px; border:1.5px solid var(--admin-border); cursor:zoom-in;">
                            </a>
                        <% } else { %>
                            <div style="width:120px; height:120px; background:var(--admin-content-bg); border-radius:8px; display:flex; align-items:center; justify-content:center; color:var(--admin-ink-soft); font-size:0.75rem;">No image</div>
                        <% } %>
                    </div>

                    <!-- Order details -->
                    <div style="flex:1; min-width:0;">
                        <div style="display:flex; justify-content:space-between; align-items:start; flex-wrap:wrap; gap:8px; margin-bottom:10px;">
                            <div>
                                <a href="/admin/orders/<%= order.id %>" class="mono" style="color:var(--admin-terracotta); font-weight:700; font-size:0.95rem;">#<%= order.order_number %></a>
                                <div style="font-size:0.85rem; color:var(--admin-ink-soft); margin-top:2px;"><%= order.customer_name %> · <%= order.customer_phone %></div>
                            </div>
                            <div style="text-align:right;">
                                <div class="mono" style="font-weight:700; font-size:1.05rem;">₹<%= Number(order.total_amount).toLocaleString('en-IN') %></div>
                                <div style="font-size:0.75rem; color:var(--admin-ink-soft);">
                                    Submitted <%= new Date(order.payment_proof_submitted_at).toLocaleString('en-IN', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' }) %>
                                </div>
                            </div>
                        </div>

                        <% if (order.upi_transaction_id) { %>
                            <div style="font-size:0.82rem; margin-bottom:14px;">
                                <span style="color:var(--admin-ink-soft);">Transaction ID:</span>
                                <span class="mono" style="font-weight:600;"><%= order.upi_transaction_id %></span>
                            </div>
                        <% } %>

                        <!-- Approve / Reject actions -->
                        <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
                            <form action="/admin/orders/<%= order.id %>/verify-payment" method="POST" style="display:inline;">
                                <input type="hidden" name="redirectTo" value="/admin/orders/verify-payments">
                                <button type="submit" class="abtn abtn--success abtn--small" data-confirm="Confirm: you have checked your bank/UPI app and ₹<%= Number(order.total_amount).toLocaleString('en-IN') %> was received for this order?">
                                    ✓ Verify & Mark Paid
                                </button>
                            </form>

                            <button type="button" class="abtn abtn--danger abtn--small" onclick="toggleRejectForm('<%= order.id %>')">
                                ✕ Reject
                            </button>

                            <a href="/admin/orders/<%= order.id %>" class="abtn abtn--secondary abtn--small">View Full Order</a>
                        </div>

                        <!-- Hidden reject reason form -->
                        <div id="reject-form-<%= order.id %>" style="display:none; margin-top:12px; padding:14px; background:var(--admin-content-bg); border-radius:8px;">
                            <form action="/admin/orders/<%= order.id %>/reject-payment" method="POST">
                                <input type="hidden" name="redirectTo" value="/admin/orders/verify-payments">
                                <div style="display:flex; gap:8px;">
                                    <input type="text" name="reason" placeholder="Reason (e.g. amount mismatch, unclear screenshot)" style="flex:1; font-size:0.82rem; padding:8px 10px;">
                                    <button type="submit" class="abtn abtn--danger abtn--small">Confirm Reject</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>

    <% if (totalPages > 1) { %>
        <div class="admin-pagination">
            <% for (let p = 1; p <= totalPages; p++) { %>
                <a href="/admin/orders/verify-payments?page=<%= p %>" class="<%= p === currentPage ? 'is-active' : '' %>"><%= p %></a>
            <% } %>
        </div>
    <% } %>
</div>

<script>
function toggleRejectForm(orderId) {
    const el = document.getElementById('reject-form-' + orderId);
    if (!el) return;
    el.style.display = el.style.display === 'none' ? 'block' : 'none';
}
</script>
