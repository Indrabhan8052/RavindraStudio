<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login — RavindraStudio</title>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin.css">
    <style>
        body { display: flex; align-items: center; justify-content: center; min-height: 100vh; background: var(--admin-sidebar-bg); }
        .login-card { background: #fff; border-radius: 14px; padding: 44px; width: 100%; max-width: 400px; box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
        .login-card__brand { display: flex; align-items: center; gap: 10px; justify-content: center; margin-bottom: 28px; }
        .login-card__brand svg { color: #B85C38; }
        .login-card__brand span { font-family: 'Fraunces', Georgia, serif; font-size: 1.4rem; font-weight: 700; color: #2B2622; }
        .login-card h1 { font-size: 1.3rem; text-align: center; margin-bottom: 6px; }
        .login-card p { text-align: center; font-size: 0.85rem; color: #6B5F57; margin-bottom: 28px; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="login-card__brand">
            <svg width="30" height="30" viewBox="0 0 34 34" fill="none">
                <rect x="3" y="3" width="20" height="20" rx="2" stroke="currentColor" stroke-width="2.5"/>
                <circle cx="26" cy="26" r="6.5" stroke="currentColor" stroke-width="2.5"/>
            </svg>
            <span>RavindraStudio</span>
        </div>
        <h1>Admin Login</h1>
        <p>Sign in to the store management panel.</p>

        <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
            <div class="form-error-list" style="margin-bottom:20px;">
                <% errors.forEach(e => { %><div><%= e.msg %></div><% }) %>
            </div>
        <% } %>

        <form action="/admin/login" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="aform-group">
                <label for="email">Admin Email</label>
                <input type="email" id="email" name="email" value="<%= oldInput && oldInput.email ? oldInput.email : '' %>" placeholder="admin@ravindrastudio.com" autofocus required>
            </div>
            <div class="aform-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Your password" required>
            </div>
            <button type="submit" class="abtn abtn--primary" style="width:100%; padding:12px; margin-top:8px; font-size:0.95rem;">Sign In →</button>
        </form>

        <p style="text-align:center; margin-top:20px; font-size:0.8rem; color:#9B9085;">
            <a href="/" style="color:#B85C38;">← Back to Store</a>
        </p>
    </div>
</body>
</html>
