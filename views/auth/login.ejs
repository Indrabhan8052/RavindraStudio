<% const pageTitle = 'Log In' %>
<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card__header">
            <svg width="40" height="40" viewBox="0 0 34 34" fill="none">
                <rect x="3" y="3" width="20" height="20" rx="2" stroke="#B85C38" stroke-width="2.5"/>
                <circle cx="26" cy="26" r="6.5" stroke="#B85C38" stroke-width="2.5"/>
            </svg>
            <h1>Welcome back</h1>
            <p>Log in to your RavindraStudio account.</p>
        </div>

        <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
            <div class="form-error-banner">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" style="flex-shrink:0"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M12 8v5M12 16h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                <ul style="list-style:disc; padding-left:14px;">
                    <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
                </ul>
            </div>
        <% } %>

        <form action="/login" method="POST" novalidate>
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <input type="hidden" name="redirectTo" value="<%= typeof redirectTo !== 'undefined' ? redirectTo : '/' %>">

            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" value="<%= oldInput && oldInput.email ? oldInput.email : '' %>" placeholder="you@example.com" autocomplete="email" autofocus>
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Your password" autocomplete="current-password">
            </div>

            <button type="submit" class="btn btn--primary btn--full" style="margin-top:8px;">Log In</button>
        </form>

        <div class="auth-card__footer">
            Don't have an account? <a href="/register">Sign up free</a>
        </div>
    </div>
</div>
