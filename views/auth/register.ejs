<% const pageTitle = 'Create Account' %>
<div class="auth-page">
    <div class="auth-card">
        <div class="auth-card__header">
            <svg width="40" height="40" viewBox="0 0 34 34" fill="none">
                <rect x="3" y="3" width="20" height="20" rx="2" stroke="#B85C38" stroke-width="2.5"/>
                <circle cx="26" cy="26" r="6.5" stroke="#B85C38" stroke-width="2.5"/>
            </svg>
            <h1>Create your account</h1>
            <p>Join RavindraStudio and start building your frame collection.</p>
        </div>

        <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
            <div class="form-error-banner">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" style="flex-shrink:0"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M12 8v5M12 16h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                <ul style="list-style:disc; padding-left:14px;">
                    <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
                </ul>
            </div>
        <% } %>

        <form action="/register" method="POST" novalidate>
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-group">
                <label for="full_name">Full Name</label>
                <input type="text" id="full_name" name="full_name" value="<%= oldInput && oldInput.full_name ? oldInput.full_name : '' %>" placeholder="e.g. Riya Sharma" autocomplete="name" class="<%= errors && errors.find(e => e.path === 'full_name') ? 'input-error' : '' %>">
            </div>

            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" value="<%= oldInput && oldInput.email ? oldInput.email : '' %>" placeholder="you@example.com" autocomplete="email" class="<%= errors && errors.find(e => e.path === 'email') ? 'input-error' : '' %>">
            </div>

            <div class="form-group">
                <label for="phone">Phone Number</label>
                <input type="tel" id="phone" name="phone" value="<%= oldInput && oldInput.phone ? oldInput.phone : '' %>" placeholder="10-digit Indian mobile" autocomplete="tel" class="<%= errors && errors.find(e => e.path === 'phone') ? 'input-error' : '' %>">
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Min. 8 chars, 1 uppercase, 1 number" autocomplete="new-password" class="<%= errors && errors.find(e => e.path === 'password') ? 'input-error' : '' %>">
                <div class="password-strength" aria-hidden="true">
                    <span></span><span></span><span></span><span></span>
                </div>
                <span class="hint">Use 8+ characters with uppercase letters and numbers.</span>
            </div>

            <div class="form-group">
                <label for="confirm_password">Confirm Password</label>
                <input type="password" id="confirm_password" name="confirm_password" placeholder="Re-enter your password" autocomplete="new-password" class="<%= errors && errors.find(e => e.path === 'confirm_password') ? 'input-error' : '' %>">
            </div>

            <div class="form-group">
                <div class="checkbox-row">
                    <input type="checkbox" id="terms" name="terms" <%= oldInput && oldInput.terms ? 'checked' : '' %>>
                    <label for="terms">I agree to the <a href="/about">Terms & Conditions</a> and <a href="/about">Privacy Policy</a>.</label>
                </div>
            </div>

            <button type="submit" class="btn btn--primary btn--full">Create Account</button>
        </form>

        <div class="auth-card__footer">
            Already have an account? <a href="/login">Log in</a>
        </div>
    </div>
</div>
