<div class="error-page">
    <svg width="80" height="80" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M9 9l6 6M15 9l-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
    <h1>Oops!</h1>
    <p><%= typeof message !== 'undefined' ? message : 'Something went wrong. Please try again.' %></p>
    <div style="display:flex; gap:14px;">
        <a href="javascript:history.back()" class="btn btn--secondary">← Go Back</a>
        <a href="/" class="btn btn--primary">Go Home</a>
    </div>
</div>
