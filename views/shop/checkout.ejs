<% const pageTitle = 'Checkout' %>
<div style="max-width:var(--container-width); margin:0 auto; padding:48px 24px 80px;">
    <h1 style="font-size:2rem; margin-bottom:32px;">Checkout</h1>

    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
        <div class="form-error-banner" style="margin-bottom:24px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" style="flex-shrink:0"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M12 8v5M12 16h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            <ul style="list-style:disc; padding-left:14px;">
                <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
            </ul>
        </div>
    <% } %>

    <form action="/checkout/place-order" method="POST" id="orderForm">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="checkout-layout">
            <div>
                <!-- Step 1: Delivery Address -->
                <div class="checkout-section">
                    <h3><span class="step-num">1</span> Delivery Address</h3>

                    <% if (addresses.length === 0) { %>
                        <p style="color:var(--color-ink-soft); margin-bottom:16px;">No saved addresses. <a href="/profile" style="color:var(--color-terracotta);">Add one in your profile →</a></p>
                    <% } else { %>
                        <% addresses.forEach((addr, i) => { %>
                            <label class="address-option">
                                <input type="radio" name="address_id" value="<%= addr.id %>" <%= i === 0 ? 'checked' : '' %> required>
                                <div>
                                    <div class="label"><%= addr.label %><%= addr.is_default ? ' · Default' : '' %></div>
                                    <div class="name"><%= addr.full_name %> · <%= addr.phone %></div>
                                    <div class="addr-text"><%= addr.address_line1 %><%= addr.address_line2 ? ', ' + addr.address_line2 : '' %>, <%= addr.city %>, <%= addr.state %> — <%= addr.pincode %></div>
                                </div>
                            </label>
                        <% }) %>
                    <% } %>

                    <details style="margin-top:16px;">
                        <summary style="cursor:pointer; font-size:0.88rem; color:var(--color-terracotta); font-weight:600;">+ Add a new address</summary>
                        <div style="margin-top:16px; padding:20px; border:1.5px dashed var(--color-border); border-radius:var(--radius-md);">
                            <p style="font-size:0.85rem; color:var(--color-ink-soft);">Please add and save addresses from your <a href="/profile" style="color:var(--color-terracotta);">Profile page</a> — they'll appear here automatically.</p>
                        </div>
                    </details>
                </div>

                <!-- Step 2: Payment Method -->
                <div class="checkout-section">
                    <h3><span class="step-num">2</span> Payment Method</h3>

                    <label class="payment-option">
                        <input type="radio" name="payment_method" value="COD" checked onchange="togglePaymentPanels()" id="pay_cod">
                        <div>
                            <strong>Cash on Delivery</strong>
                            <span>Pay with cash when your order arrives at your doorstep.</span>
                        </div>
                    </label>

                    <label class="payment-option">
                        <input type="radio" name="payment_method" value="UPI" onchange="togglePaymentPanels()" id="pay_upi">
                        <div>
                            <strong>UPI / QR Code Payment</strong>
                            <span>Scan the QR or pay to our UPI ID, then upload your payment screenshot.</span>
                        </div>
                    </label>

                    <!-- UPI QR panel — hidden until UPI is selected -->
                    <div id="upiPanel" style="display:none; margin-top:-4px; margin-bottom:16px; padding:24px; background:var(--color-bg-alt); border-radius:var(--radius-md); border:1.5px solid var(--color-border); text-align:center;">
                        <% if (upiQrImage) { %>
                            <img src="<%= upiQrImage %>" alt="UPI QR Code" style="width:200px; height:200px; object-fit:contain; background:#fff; padding:12px; border-radius:var(--radius-sm); box-shadow:var(--shadow-sm); margin-bottom:14px;">
                        <% } %>
                        <% if (upiId) { %>
                            <p style="font-size:0.82rem; color:var(--color-ink-soft); margin-bottom:4px;">Pay to UPI ID</p>
                            <p style="font-family:var(--font-mono); font-size:1.1rem; font-weight:700; color:var(--color-terracotta); margin-bottom:4px;"><%= upiId %></p>
                            <% if (upiPayeeName) { %><p style="font-size:0.8rem; color:var(--color-ink-soft);">(<%= upiPayeeName %>)</p><% } %>
                        <% } else { %>
                            <p style="font-size:0.85rem; color:var(--color-ink-soft);">UPI details have not been set up yet. Please choose Cash on Delivery, or contact us.</p>
                        <% } %>
                        <p style="font-size:0.78rem; color:var(--color-ink-soft); margin-top:16px; line-height:1.6;">
                            ⓘ After placing your order, you'll be asked to upload a screenshot of this payment for verification.
                        </p>
                    </div>

                    <div class="form-group" style="margin-top:16px;">
                        <label for="notes">Order Notes (optional)</label>
                        <textarea name="notes" id="notes" rows="2" placeholder="Special instructions, gift messages, etc."></textarea>
                    </div>
                </div>
            </div>

            <!-- Order Summary -->
            <div>
                <div class="order-summary">
                    <h3>Order Review</h3>
                    <% items.forEach(item => {
                        const unitPrice = item.discount_price ? Number(item.discount_price) : Number(item.price);
                    %>
                        <div class="order-review-item">
                            <div class="order-review-item__media">
                                <%- include('../partials/shape-image', { shape: item.icon_shape || 'square', imageUrl: item.primary_image, alt: item.name }) %>
                            </div>
                            <div>
                                <div class="order-review-item__title"><%= item.name %></div>
                                <div class="order-review-item__qty">Qty: <%= item.quantity %></div>
                            </div>
                            <div class="order-review-item__price">₹<%= (unitPrice * item.quantity).toLocaleString('en-IN') %></div>
                        </div>
                    <% }) %>

                    <% if (typeof appliedCoupon !== 'undefined' && appliedCoupon) { %>
                        <input type="hidden" name="coupon_code" value="<%= appliedCoupon.code %>">
                        <div class="applied-coupon">
                            <span>🏷 <%= appliedCoupon.code %> applied</span>
                            <strong>−₹<%= Number(discount).toLocaleString('en-IN') %></strong>
                        </div>
                    <% } else { %>
                        <div class="coupon-row" style="margin-top:16px;">
                            <input type="text" id="couponInput" placeholder="Coupon code" style="font-family:var(--font-mono); font-size:0.88rem; text-transform:uppercase;">
                            <button type="button" class="btn btn--small btn--outline" onclick="applyCoupon()">Apply</button>
                        </div>
                    <% } %>

                    <div class="order-summary__row">
                        <span>Subtotal</span>
                        <span>₹<%= subtotal.toLocaleString('en-IN') %></span>
                    </div>
                    <div class="order-summary__row">
                        <span>Shipping</span>
                        <span class="<%= shippingFee === 0 ? 'free' : '' %>"><%= shippingFee === 0 ? 'FREE' : '₹' + shippingFee %></span>
                    </div>
                    <% if (typeof discount !== 'undefined' && discount > 0) { %>
                        <div class="order-summary__row" style="color:var(--color-success);">
                            <span>Discount</span>
                            <span>−₹<%= Number(discount).toLocaleString('en-IN') %></span>
                        </div>
                    <% } %>
                    <div class="order-summary__row total">
                        <span>Total to Pay</span>
                        <span>₹<%= Number(total).toLocaleString('en-IN') %></span>
                    </div>

                    <button type="submit" class="btn btn--primary btn--full" style="margin-top:20px;">
                        Place Order →
                    </button>
                    <p style="text-align:center; margin-top:12px; font-size:0.76rem; color:var(--color-ink-soft);">By placing your order, you agree to our terms.</p>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
function applyCoupon() {
    const code = document.getElementById('couponInput').value.trim();
    if (!code) return;
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/checkout/apply-coupon';
    const input = document.createElement('input');
    input.type = 'hidden'; input.name = 'coupon_code'; input.value = code;
    form.appendChild(input);
    document.body.appendChild(form);
    form.submit();
}

function togglePaymentPanels() {
    const upiPanel = document.getElementById('upiPanel');
    const isUpi = document.getElementById('pay_upi').checked;
    upiPanel.style.display = isUpi ? 'block' : 'none';
}
</script>
