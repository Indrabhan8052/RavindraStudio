<% const pageTitle = 'Home' %>

<section class="hero">
    <div class="hero__inner">
        <div class="hero__copy">
            <span class="hero__eyebrow">Handpicked Frames, Personally Curated</span>
            <h1>Frame every <em>memory</em>,<br>beautifully.</h1>
            <p>Square, circle, heart and more — find the perfect shape to hold the moments you don't want to forget. Every frame, chosen with care.</p>
            <div class="hero__ctas">
                <a href="/products" class="btn btn--primary">Shop All Frames</a>
                <a href="/products?category=heart-frames" class="btn btn--secondary">Heart Collection</a>
            </div>
        </div>
        <div class="hero__wall" aria-hidden="true">
            <div class="hero__frame hero__frame--1"><img src="https://images.unsplash.com/photo-1581291518633-83b4ebd1d83e?w=400&q=80" alt=""></div>
            <div class="hero__frame hero__frame--2"><img src="https://images.unsplash.com/photo-1530841344095-c997d2a9b3dc?w=400&q=80" alt=""></div>
            <div class="hero__frame hero__frame--3"><img src="https://images.unsplash.com/photo-1518621012420-8ab10887ea36?w=400&q=80" alt=""></div>
            <div class="hero__frame hero__frame--4"><img src="https://images.unsplash.com/photo-1499728603263-13726abce5fd?w=400&q=80" alt=""></div>
        </div>
    </div>
</section>

<div class="value-strip">
    <div class="value-strip__grid">
        <div class="value-strip__item">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <div><strong>Cash on Delivery</strong><span>Pay when your frame arrives</span></div>
        </div>
        <div class="value-strip__item">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="2"/><path d="M3 9h18M9 21V9" stroke="currentColor" stroke-width="2"/></svg>
            <div><strong>8 Shape Categories</strong><span>Square to hexagon, all in stock</span></div>
        </div>
        <div class="value-strip__item">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none"><path d="M12 21s-7.5-4.873-10-9.5C0.5 7.5 2.5 3 7 3c2.5 0 4 1.5 5 3 1-1.5 2.5-3 5-3 4.5 0 6.5 4.5 5 8.5C19.5 16.127 12 21 12 21z" stroke="currentColor" stroke-width="2"/></svg>
            <div><strong>Made with Care</strong><span>A small shop, personally run</span></div>
        </div>
    </div>
</div>

<section class="section">
    <div class="section__header">
        <div>
            <span class="section__eyebrow">Shop by Shape</span>
            <h2>Every memory has a shape</h2>
            <p>From classic squares to romantic hearts — choose the frame shape that fits your moment.</p>
        </div>
        <a href="/products" class="btn btn--outline btn--small">View All →</a>
    </div>

    <div class="category-grid">
        <% categories.slice(0, 8).forEach(cat => { %>
            <a href="/products?category=<%= cat.slug %>" class="category-card">
                <div class="category-card__shape">
                    <div class="shape-<%= cat.icon_shape %>" style="width:48px; height:48px; background: var(--color-terracotta); opacity: 0.15;"></div>
                </div>
                <h3><%= cat.name %></h3>
                <p><%= cat.description ? cat.description.slice(0, 40) + '…' : '' %></p>
            </a>
        <% }) %>
    </div>
</section>

<% if (featuredProducts && featuredProducts.length > 0) { %>
<section class="section section--alt">
    <div class="section__header">
        <div>
            <span class="section__eyebrow">Customer Favorites</span>
            <h2>Featured Frames</h2>
        </div>
        <a href="/products" class="btn btn--outline btn--small">Browse All →</a>
    </div>

    <div class="product-grid">
        <% featuredProducts.forEach(product => { %>
            <%- include('../partials/product-card', { product }) %>
        <% }) %>
    </div>
</section>
<% } %>

<% if (newArrivals && newArrivals.length > 0) { %>
<section class="section">
    <div class="section__header">
        <div>
            <span class="section__eyebrow">Just In</span>
            <h2>New Arrivals</h2>
        </div>
        <a href="/products?sort=newest" class="btn btn--outline btn--small">See More →</a>
    </div>

    <div class="product-grid">
        <% newArrivals.slice(0, 4).forEach(product => { %>
            <%- include('../partials/product-card', { product }) %>
        <% }) %>
    </div>
</section>
<% } %>
