<% const pageTitle = product.name %>
<%
const hasDiscount = product.discount_price && Number(product.discount_price) < Number(product.price);
const offPercent = hasDiscount ? Math.round(100 - (product.discount_price / product.price) * 100) : 0;
const mainImage = product.images && product.images.length > 0 ? product.images[0].image_path : null;
%>

<div class="product-detail">
    <div class="breadcrumb">
        <a href="/">Home</a> <span>/</span>
        <a href="/products?category=<%= product.category_slug %>"><%= product.category_name %></a> <span>/</span>
        <span><%= product.name %></span>
    </div>

    <div class="product-detail__grid">
        <div class="product-gallery">
            <div class="product-gallery__main">
                <div class="shape-frame shape-<%= product.icon_shape %>">
                    <img data-gallery-main src="<%= mainImage || '/images/placeholder-frame.svg' %>" alt="<%= product.name %>">
                </div>
            </div>
            <% if (product.images && product.images.length > 1) { %>
                <div class="product-gallery__thumbs">
                    <% product.images.forEach((img, i) => { %>
                        <button type="button" data-gallery-thumb data-image="<%= img.image_path %>" class="<%= i === 0 ? 'is-active' : '' %>">
                            <img src="<%= img.image_path %>" alt="<%= product.name %> view <%= i + 1 %>">
                        </button>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <div class="product-info">
            <span class="product-info__category"><%= product.category_name %></span>
            <h1><%= product.name %></h1>

            <div class="product-info__rating">
                <span class="stars">★★★★★</span>
                <span><%= product.rating_avg > 0 ? product.rating_avg : 'No ratings yet' %> <% if (product.rating_count > 0) { %>· <%= product.rating_count %> review<%= product.rating_count !== 1 ? 's' : '' %><% } %></span>
            </div>

            <div class="product-info__price">
                <span class="current">₹<%= Number(hasDiscount ? product.discount_price : product.price).toLocaleString('en-IN') %></span>
                <% if (hasDiscount) { %>
                    <span class="original">₹<%= Number(product.price).toLocaleString('en-IN') %></span>
                    <span class="off"><%= offPercent %>% off</span>
                <% } %>
            </div>
            <p class="product-info__gst">Inclusive of all taxes</p>

            <% if (product.description) { %><p class="product-info__desc"><%= product.description %></p><% } %>

            <table class="spec-table">
                <tr><td>Material</td><td><%= product.material %></td></tr>
                <tr><td>Size</td><td><%= product.size %></td></tr>
                <tr><td>Color</td><td><%= product.color %></td></tr>
                <tr><td>SKU</td><td><%= product.sku || '—' %></td></tr>
            </table>

            <% if (product.stock_quantity === 0) { %>
                <p class="stock-note out-of-stock">● Out of Stock</p>
            <% } else if (product.stock_quantity <= 5) { %>
                <p class="stock-note low-stock">● Only <%= product.stock_quantity %> left — order soon</p>
            <% } else { %>
                <p class="stock-note in-stock">● In Stock</p>
            <% } %>

            <% if (currentUser && currentUser.role === 'customer') { %>
                <div class="product-actions">
                    <form action="/cart/add" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="product_id" value="<%= product.id %>">
                        <input type="hidden" name="redirectTo" value="/products/<%= product.slug %>">
                        <div class="qty-stepper">
                            <button type="button" data-action="decrease">−</button>
                            <input type="number" name="quantity" value="1" min="1" max="<%= product.stock_quantity %>">
                            <button type="button" data-action="increase">+</button>
                        </div>
                        <button type="submit" class="btn btn--primary" <%= product.stock_quantity === 0 ? 'disabled' : '' %>>
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M3 3h2l2.4 12.4a2 2 0 002 1.6h8.4a2 2 0 002-1.6L21 8H6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                            Add to Cart
                        </button>
                    </form>
                    <form action="/wishlist/toggle" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <input type="hidden" name="product_id" value="<%= product.id %>">
                        <input type="hidden" name="redirectTo" value="/products/<%= product.slug %>">
                        <button type="submit" class="btn btn--secondary" title="Add to wishlist">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="<%= isWishlisted ? 'currentColor' : 'none' %>"><path d="M12 21s-7.5-4.873-10-9.5C0.5 7.5 2.5 3 7 3c2.5 0 4 1.5 5 3 1-1.5 2.5-3 5-3 4.5 0 6.5 4.5 5 8.5C19.5 16.127 12 21 12 21z" stroke="currentColor" stroke-width="2"/></svg>
                        </button>
                    </form>
                </div>
            <% } else { %>
                <div class="product-actions">
                    <a href="/login?redirect=/products/<%= product.slug %>" class="btn btn--primary">Log In to Buy</a>
                </div>
            <% } %>

            <div class="trust-badges">
                <div class="trust-badge">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Cash on Delivery available
                </div>
                <div class="trust-badge">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M21 8L12 2 3 8v8l9 6 9-6V8z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/></svg>
                    Carefully packaged
                </div>
                <div class="trust-badge">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2"/><path d="M12 7v5l3 3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    Ships in 2-4 business days
                </div>
            </div>
        </div>
    </div>
</div>

<% if (related && related.length > 0) { %>
<section class="section section--alt">
    <div class="section__header">
        <div><span class="section__eyebrow">You Might Also Like</span><h2>More from <%= product.category_name %></h2></div>
    </div>
    <div class="product-grid">
        <% related.forEach(p => { p.icon_shape = product.icon_shape; %>
            <%- include('../partials/product-card', { product: p }) %>
        <% }) %>
    </div>
</section>
<% } %>

<section class="reviews-section">
    <h2 style="margin-bottom: 24px;">Customer Reviews</h2>

    <div class="reviews-summary">
        <div class="reviews-summary__score">
            <div class="num"><%= product.rating_avg > 0 ? product.rating_avg : '—' %></div>
            <div class="stars">★★★★★</div>
            <div style="font-size:0.82rem; color: var(--color-ink-soft);"><%= reviewCount %> review<%= reviewCount !== 1 ? 's' : '' %></div>
        </div>
        <div>
            <p style="color: var(--color-ink-soft); font-size: 0.92rem;">Reviews are from verified buyers who purchased and received this product. Honest feedback helps everyone choose the right frame.</p>
        </div>
    </div>

    <% if (reviews.length === 0) { %>
        <p style="color: var(--color-ink-soft); padding: 20px 0;">No reviews yet. Be the first to share your thoughts!</p>
    <% } else { %>
        <% reviews.forEach(review => { %>
            <div class="review-card">
                <div class="review-card__head">
                    <span class="review-card__author"><%= review.full_name %></span>
                    <span class="review-card__date"><%= new Date(review.created_at).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                </div>
                <span class="stars"><%= '★'.repeat(review.rating) %><%= '☆'.repeat(5 - review.rating) %></span>
                <% if (review.comment) { %><p style="color: var(--color-ink-soft); font-size: 0.92rem;"><%= review.comment %></p><% } %>
            </div>
        <% }) %>
    <% } %>

    <% if (canReview) { %>
        <div class="review-form">
            <h3 style="margin-bottom: 16px;">Write a Review</h3>
            <form action="/products/<%= product.slug %>/review" method="POST">
                <div class="form-group">
                    <label>Your Rating</label>
                    <div class="star-input">
                        <% [5,4,3,2,1].forEach(n => { %>
                            <input type="radio" name="rating" id="star<%= n %>" value="<%= n %>" <%= n === 5 ? 'checked' : '' %>>
                            <label for="star<%= n %>">★</label>
                        <% }) %>
                    </div>
                </div>
                <div class="form-group">
                    <label for="comment">Your Review (optional)</label>
                    <textarea name="comment" id="comment" placeholder="Tell others what you think about this frame..."></textarea>
                </div>
                <button type="submit" class="btn btn--primary">Submit Review</button>
            </form>
        </div>
    <% } else if (currentUser && currentUser.role === 'customer') { %>
        <p style="color: var(--color-ink-soft); font-size: 0.85rem; margin-top: 20px;">Only customers who have purchased and received this product can leave a review.</p>
    <% } %>
</section>
