<% const pageTitle = 'Contact Us' %>
<div style="max-width:700px; margin:0 auto; padding:64px 24px 80px;">
    <div style="text-align:center; margin-bottom:48px;">
        <span style="font-family:var(--font-mono); font-size:0.75rem; letter-spacing:0.08em; text-transform:uppercase; color:var(--color-sage);">Get in Touch</span>
        <h1 style="font-size:2.4rem; margin-top:8px;">We'd love to hear from you</h1>
        <p style="color:var(--color-ink-soft); margin-top:10px;">Questions, custom orders, or just a hello — send us a message and we'll get back to you.</p>
    </div>

    <% if (typeof errors !== 'undefined' && errors.length > 0) { %>
        <div class="form-error-banner" style="margin-bottom:20px;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" style="flex-shrink:0"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M12 8v5M12 16h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
            <ul style="list-style:disc; padding-left:14px;">
                <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
            </ul>
        </div>
    <% } %>

    <div style="background:var(--color-card); border:1px solid var(--color-border); border-radius:var(--radius-lg); padding:40px;">
        <form action="/contact" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="form-row">
                <div class="form-group">
                    <label for="name">Your Name</label>
                    <input type="text" id="name" name="name" value="<%= currentUser ? currentUser.full_name : (oldInput && oldInput.name ? oldInput.name : '') %>" placeholder="Full name" required>
                </div>
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" name="email" value="<%= currentUser ? currentUser.email : (oldInput && oldInput.email ? oldInput.email : '') %>" placeholder="your@email.com" required>
                </div>
            </div>
            <div class="form-group">
                <label for="subject">Subject</label>
                <input type="text" id="subject" name="subject" value="<%= oldInput && oldInput.subject ? oldInput.subject : '' %>" placeholder="What's this about?">
            </div>
            <div class="form-group">
                <label for="message">Message</label>
                <textarea id="message" name="message" rows="5" placeholder="Tell us more…" required><%= oldInput && oldInput.message ? oldInput.message : '' %></textarea>
            </div>
            <button type="submit" class="btn btn--primary btn--full">Send Message</button>
        </form>
    </div>
</div>
