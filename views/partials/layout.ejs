<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' | RavindraStudio' : 'RavindraStudio — Frame Every Memory, Beautifully' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <%- include("./csrf-meta") %>
</head>
<body>
    <%- include('./header') %>

    <% if (typeof successMessages !== 'undefined' && successMessages.length > 0) { %>
        <div class="flash-stack">
            <% successMessages.forEach(msg => { %>
                <div class="flash flash--success" role="status">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span><%= msg %></span>
                </div>
            <% }) %>
        </div>
    <% } %>
    <% if (typeof errorMessages !== 'undefined' && errorMessages.length > 0) { %>
        <div class="flash-stack">
            <% errorMessages.forEach(msg => { %>
                <div class="flash flash--error" role="alert">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M12 8v5M12 16h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    <span><%= msg %></span>
                </div>
            <% }) %>
        </div>
    <% } %>

    <main>
        <%- body %>
    </main>

    <%- include('./footer') %>

    <script src="/js/main.js"></script>
    <script src="/js/search.js"></script>
</body>
</html>
