# ============================================================
# FrameKraft — Environment Configuration
# Copy this file to ".env" for local dev
# On Render/Railway: paste these as Environment Variables in the dashboard
# NEVER commit the real .env file to Git
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=development
# Set NODE_ENV=production on your hosting platform

# --- MySQL Database ---
# Local (XAMPP): leave DB_PASSWORD blank
# Production: use the connection string from your hosting DB panel
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=framekraft_db

# --- Session ---
# Generate a strong random string: openssl rand -hex 32
# MUST be a long random string in production — never leave as default
SESSION_SECRET=change_this_to_a_very_long_random_string_at_least_32_chars

# --- Admin Seed Account ---
ADMIN_EMAIL=admin@framekraft.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Store Admin

# --- Cloudinary (for image uploads in production) ---
# Sign up free at cloudinary.com → Dashboard → copy these 3 values
# Required in production. In development, local disk uploads still work.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- App URL (used for absolute links in production) ---
APP_URL=https://yourdomain.com
